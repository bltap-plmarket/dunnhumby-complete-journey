{
  "name": "dunnhumby Complete Journey",
  "$comment": "Power BI theme JSON. Import via View > Themes > Browse for themes. Palette is intentionally retail-friendly with a clear good/neutral/bad axis for trend visuals.",
  "dataColors": [
    "#1F4E79",
    "#2E75B6",
    "#5B9BD5",
    "#A5C8E1",
    "#70AD47",
    "#C00000",
    "#ED7D31",
    "#FFC000",
    "#7030A0",
    "#404040"
  ],
  "background": "#FFFFFF",
  "foreground": "#1F4E79",
  "tableAccent": "#1F4E79",
  "good": "#70AD47",
  "neutral": "#A6A6A6",
  "bad": "#C00000",
  "maximum": "#1F4E79",
  "center": "#FFFFFF",
  "minimum": "#C00000",
  "null": "#A6A6A6",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 18,
      "color": "#1F4E79"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12,
      "color": "#1F4E79"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#404040"
    },
    "callout": {
      "fontFace": "Segoe UI Light",
      "fontSize": 36,
      "color": "#1F4E79"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [{"show": true, "color": {"solid": {"color": "#FFFFFF"}}, "transparency": 0}],
        "border":     [{"show": false}]
      }
    }
  }
}
